{
  "framework": "create-react-app",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install",
  "devCommand": "npm start",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/email/send-weekly-digest",
      "schedule": "0 9 * * 0"
    },
    {
      "path": "/api/email/send-daily-digest", 
      "schedule": "0 9 * * 1-5"
    },
    {
      "path": "/api/admin/check-premium-expiry",
      "schedule": "0 6 * * *"
    }
  ]
}
